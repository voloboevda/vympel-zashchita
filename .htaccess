# .htaccess для Beget / статический лендинг вымпел-защита.рф

RewriteEngine On

# --- Canonical host + HTTPS (apex, no www) ---
# www → apex
RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
RewriteRule ^ https://%1%{REQUEST_URI} [R=301,L]

# HTTP → HTTPS (when HTTPS env is off; Beget usually sets HTTPS)
RewriteCond %{HTTPS} !=on
RewriteCond %{HTTP:X-Forwarded-Proto} !=https
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

# --- Removed sections: always 404 (even if folders reappear) ---
RewriteRule ^(blog|services|admin)(/.*)?$ - [R=404,L]
RewriteRule ^_archive(/.*)?$ - [R=404,L]

# Форма: /api/leads и /api/leads/ → leads.php
# Нельзя rewrite'ить leads.php на себя — будет цикл и HTTP 500.
RewriteRule ^api/leads/?$ api/leads.php [L,QSA]

# SEO / статика
AddDefaultCharset UTF-8

# Favicon MIME types (helps Yandex/Google pick the right icon)
<IfModule mod_mime.c>
  AddType image/x-icon .ico
  AddType image/svg+xml .svg
  AddType image/png .png
</IfModule>

<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/png "access plus 1 month"
  ExpiresByType image/jpeg "access plus 1 month"
  ExpiresByType image/webp "access plus 1 month"
  ExpiresByType image/x-icon "access plus 1 month"
  ExpiresByType text/css "access plus 1 week"
  ExpiresByType application/javascript "access plus 1 week"
  ExpiresByType text/html "access plus 1 hour"
</IfModule>

<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/css application/javascript application/json image/svg+xml
</IfModule>

<Files "leads.json">
  Order Allow,Deny
  Deny from all
</Files>


ErrorDocument 404 /404.html

<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set X-X-XSS-Protection "1; mode=block"
</IfModule>

# Force revalidate homepage HTML
<IfModule mod_headers.c>
  <FilesMatch "^index\\.html$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires "0"
  </FilesMatch>
</IfModule>
